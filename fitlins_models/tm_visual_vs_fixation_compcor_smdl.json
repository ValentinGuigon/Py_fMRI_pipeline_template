{
  "Name": "tmVisualVsFixation_SubjectPool",
  "BIDSModelVersion": "1.0.0",
  "Input": {
    "task": ["tm1", "tm2"],
    "subject": ["000", "001", "002", "003"]
  },
  "Nodes": [
    {
      "Level": "Run",
      "Name": "runLevel",
      "GroupBy": ["subject", "task", "run"],
      "Transformations": {
        "Transformer": "pybids-transforms-v1",
        "Instructions": [
          { "Name": "Factor", "Input": ["trial_type"] }
        ]
      },
      "Model": {
        "Type": "glm",
        "X": [
          "trial_type.choice",
          "trial_type.wait",
          "trial_type.feedback",
          "trial_type.fixation",
          "framewise_displacement",
          "trans_x", "trans_y", "trans_z",
          "rot_x", "rot_y", "rot_z",
          "a_comp_cor_00", "a_comp_cor_01", "a_comp_cor_02",
          "a_comp_cor_03", "a_comp_cor_04", "a_comp_cor_05"
        ]
      },
      "Contrasts": [
        {
          "Name": "visualGtFixation",
          "ConditionList": [
            "trial_type.choice",
            "trial_type.wait",
            "trial_type.feedback",
            "trial_type.fixation"
          ],
          "Weights": [0.3333333333333333, 0.3333333333333333, 0.3333333333333333, -1.0],
          "Test": "t"
        }
      ]
    },
    {
      "Level": "Subject",
      "Name": "subjectLevel",
      "GroupBy": ["subject", "contrast"],
      "Transformations": {
        "Transformer": "pybids-transforms-v1",
        "Instructions": [
          { "Name": "FixedEffects", "Input": ["contrast"] }
        ]
      },
      "Model": {
        "Type": "meta",
        "X": [1]
      },
      "DummyContrasts": {
        "Test": "t"
      }
    }
  ]
}
