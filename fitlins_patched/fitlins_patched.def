Bootstrap: docker
From: mambaorg/micromamba:1.5.10

%labels
    Author vguigon
    Purpose "FitLins 0.11.0 stable stack (pybids 0.15.x, pandas 1.5)"

%environment
    # Quiet, writable matplotlib config for HPC / SLURM
    export MPLCONFIGDIR=/tmp/mplconfig
    export PATH=/opt/conda/envs/fitlins/bin:$PATH

%files
    environment.yml /environment.yml

%post
    set -e

    # Minimal system dependencies
    apt-get update
    apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
    && rm -rf /var/lib/apt/lists/*

    # Create FitLins environment
    micromamba create -y -n fitlins -f /environment.yml
    # --- Patch PyBIDS entities.py: sanitize pandas query strings before DataFrame.query() ---
/opt/conda/envs/fitlins/bin/python - <<'PY'
import pathlib, re

p = pathlib.Path("/opt/conda/envs/fitlins/lib/python3.9/site-packages/bids/variables/entities.py")
txt = p.read_text()

helper_name = "_sanitize_pandas_query"
if helper_name not in txt:
    helper = r'''
def _sanitize_pandas_query(df, expr):
    """Split a query expression into pandas-safe and dict-literal parts,
    evaluate both, and return the combined boolean mask."""
    import re
    import ast

    if not isinstance(expr, str) or not expr.strip():
        return df

    # Pattern to capture: <col> == {<dict_body>}
    dict_pat = re.compile(r'(\w+)\s*==\s*(\{[^}]*\})')

    dict_conditions = []
    clean_parts = []

    # Split on ' and ' to get individual conjuncts
    conjuncts = re.split(r'\s+and\s+', expr.strip())

    for conj in conjuncts:
        m = dict_pat.fullmatch(conj.strip())
        if m:
            col_name = m.group(1)
            try:
                val = ast.literal_eval(m.group(2))
                dict_conditions.append((col_name, val))
            except (ValueError, SyntaxError):
                # Can't parse it — keep it in the query string,
                # let pandas raise so you hear about it
                clean_parts.append(conj)
        else:
            clean_parts.append(conj)

    # Evaluate the pandas-safe portion
    clean_expr = " and ".join(clean_parts)
    if clean_expr:
        result = df.query(clean_expr)
    else:
        result = df

    # Apply dict conditions via normal Python equality
    for col_name, val in dict_conditions:
        if col_name in result.columns:
            result = result[result[col_name].apply(lambda x: x == val)]

    return result
'''
    # Insert helper after first blank line (post-import block)
    m = re.search(r"\n\n", txt)
    if not m:
        raise SystemExit("Unexpected entities.py format: no insertion point for helper")
    txt = txt[:m.end()] + helper + txt[m.end():]

# Find a call like: self.index.query(query_var)
m = re.search(r"self\.index\.query\(\s*([A-Za-z_][A-Za-z0-9_]*)\s*\)", txt)
if not m:
    raise SystemExit("Could not find self.index.query(<var>) in entities.py; patch target not found")

var = m.group(1)

# Inject '<var> = _sanitize_pandas_query(<var>)' immediately before the query call line
# Determine indentation of the line containing the call
line_start = txt.rfind("\n", 0, m.start()) + 1
line_end = txt.find("\n", m.start())
call_line = txt[line_start:line_end]
indent = re.match(r"[ \t]*", call_line).group(0)

injection = f"{indent}{var} = _sanitize_pandas_query({var})\n"

# Avoid double-injecting
pre_window_start = max(0, line_start - 300)
pre_window = txt[pre_window_start:line_start]
if helper_name in pre_window and f"{var} = {helper_name}({var})" in pre_window:
    # already patched
    pass
else:
    txt = txt[:line_start] + injection + txt[line_start:]

p.write_text(txt)
print("Patched:", p)
print("Injected sanitization for variable:", var)
PY

    micromamba clean -a -y

    # Sanity checks (fail early if anything is wrong)
    /opt/conda/envs/fitlins/bin/python -c "import sys; print('python', sys.version)"
    /opt/conda/envs/fitlins/bin/python -c \
      "import bids, pandas, fitlins, nipype, nilearn, matplotlib; \
       print('fitlins', fitlins.__version__); \
       print('pybids', bids.__version__); \
       print('pandas', pandas.__version__); \
       print('nipype', nipype.__version__); \
       print('nilearn', nilearn.__version__); \
       print('matplotlib', matplotlib.__version__)"

%runscript
    exec /opt/conda/envs/fitlins/bin/fitlins "$@"
